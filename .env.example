# Macgear 3PL Portal — droplet env. Copy to `.env` and fill in. NEVER commit the real .env.
# The app needs NO NetSuite credentials — those live only in the n8n Code node.

# --- App ---
# Cookie-signing secret. Generate: openssl rand -hex 32
APP_SECRET=change-me-to-a-long-random-hex
# Shared secret for /admin/ingest + /admin/billing/* (must equal SYNC_TOKEN in the n8n node).
# Generate: openssl rand -hex 32
SYNC_TOKEN=change-me-to-a-long-random-hex
# 0 = clean deploy (customers + rate cards + users only). 1 = also plant demo cache rows.
SEED_DEMO=0

# --- Password reset / set-password links ---
# Public origin used to build reset links (behind Caddy). e.g. https://3pl.macgeargroup.com
PUBLIC_BASE_URL=https://3pl.macgeargroup.com
# n8n webhook that emails the reset link via its Outlook node. Unset = link is logged to the
# console instead of sent (fine for local dev).
N8N_RESET_WEBHOOK_URL=
# Shared secret sent as X-Sync-Token to the webhook above. Blank = reuse SYNC_TOKEN.
N8N_WEBHOOK_TOKEN=
# Minutes a reset/set-password link stays valid.
RESET_TOKEN_TTL_MIN=45

# --- Database ---
# Bundled Postgres (this compose). Keep PGPASSWORD and the password in DATABASE_URL identical.
PGPASSWORD=change-me-strong-db-password
DATABASE_URL=postgresql+psycopg2://threepl:change-me-strong-db-password@threepl-db:5432/threepl
# To use managed Postgres instead, point DATABASE_URL at it and remove the threepl-db service.

# --- Networking ---
# Name of the existing Docker network shared with Caddy + n8n (docker network ls).
SHARED_NETWORK=web
